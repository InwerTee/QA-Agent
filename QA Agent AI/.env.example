# Required only when using the OpenAI-backed planner.
OPENAI_API_KEY=

# Override if needed. Keep this configurable because model access can vary by account.
OPENAI_MODEL=gpt-5.5

# Browser command adapter. The runner will try this command first.
PLAYWRIGHT_CLI_COMMAND=playwright-cli

# Optional base URL used by plans that need a starting page.
GRO_BASE_URL=https://staging-gro.paradev.io
