{
  "name": "gro-qa-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "preqa": "npm run build --silent",
    "qa": "node dist/src/cli.js",
    "qa:list:r6": "npm run qa -- list R6",
    "qa:plan:r6": "npm run qa -- plan R6 --case R6-B7.2-TC01 --case R6-B7.1-TC01",
    "qa:run:r6": "npm run qa -- run R6 --case R6-B7.2-TC01 --case R6-B7.1-TC01",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@playwright/test": "^1.45.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.3"
  }
}
