# Gro QA Agent environment example
#
# Copy this file to .env and fill real staging values locally.
# Do not commit .env. Do not paste credentials into prompts, reports, comments, or logs.

# Admin Site.
QA_ADMIN_BASE_URL=
QA_ADMIN_LOGIN_URL=
QA_ADMIN_USERNAME=
QA_ADMIN_PASSWORD=

# Creator Site. Fill only in local .env when running creator-side cases.
QA_CREATOR_BASE_URL=
QA_CREATOR_LOGIN_URL=
QA_CREATOR_USERNAME=
QA_CREATOR_PASSWORD=

# Agency Site. Fill only in local .env when running agency-side cases.
QA_AGENCY_BASE_URL=
QA_AGENCY_LOGIN_URL=
QA_AGENCY_USERNAME=
QA_AGENCY_PASSWORD=

# Optional: fixed verification code if staging provides one.
QA_ADMIN_VERIFICATION_CODE=
QA_CREATOR_VERIFICATION_CODE=
QA_AGENCY_VERIFICATION_CODE=

# Optional: reuse an existing Playwright storage state JSON.
# Leave blank to use the default storage-state path for each site.
QA_ADMIN_STORAGE_STATE=
QA_CREATOR_STORAGE_STATE=
QA_AGENCY_STORAGE_STATE=
QA_STORAGE_TTL_MS=86400000
QA_FORCE_RELOGIN=false

# Optional browser/runtime controls.
QA_HEADLESS=true
QA_EVIDENCE_DIR=reports/runs
