# Gro QA Agent environment example
#
# Copy this file to .env and fill real staging values locally.
# Do not commit .env. Do not paste credentials into prompts, reports, comments, or logs.

# Admin Site is enough for the first R6 Master Campaign pilot.
QA_ADMIN_BASE_URL=
QA_ADMIN_LOGIN_URL=
QA_ADMIN_USERNAME=
QA_ADMIN_PASSWORD=

# Optional: fixed admin verification code if staging provides one.
QA_ADMIN_VERIFICATION_CODE=

# Optional: reuse an existing Playwright storage state JSON.
# Leave blank to use QA Agent/storage-state/admin.json.
QA_ADMIN_STORAGE_STATE=
QA_STORAGE_TTL_MS=86400000
QA_FORCE_RELOGIN=false

# Optional browser/runtime controls.
QA_HEADLESS=true
QA_EVIDENCE_DIR=reports/runs
